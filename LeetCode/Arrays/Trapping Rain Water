Problem: Trapping Rain Water
Topic: Arrays, Two Pointers
Difficulty: Hard

Approach:
Use two pointers from both ends while maintaining left_max and right_max. At each step, move the pointer with smaller height and calculate trapped water based on the difference between current height and corresponding max.

Time Complexity: O(n)
Space Complexity: O(1)

Code:
class Solution {
public:
    int trap(vector<int>& height) {
        int left=0;
        int right=height.size()-1;
        int left_max=0;
        int right_max=0;
        int water_trapped=0;

        while(left<right){
            if(height[left]<=height[right]){
                if(height[left]>=left_max){
                    left_max=height[left];
                }
                else{
                    water_trapped+=left_max-height[left];
                }
                left++;
            }
            else{
                if(height[right]>=right_max){
                    right_max=height[right];
                }
                else{
                    water_trapped+=right_max-height[right];
                }
                right--;
            }
        }
        return water_trapped;
    }
};
