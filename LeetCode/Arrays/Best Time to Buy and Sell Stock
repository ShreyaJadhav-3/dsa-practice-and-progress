//Optimal Approach:
class Solution {
public:
   int maxProfit(vector<int>& prices){
    int profit=0;
    int i=0;
    int j=1;
int n=prices.size();
    while(j<n){
        int currprofit=prices[j]-prices[i];
        if(prices[j]<prices[i]){
            i++;
        }
        else{
            if(currprofit>profit){
                profit=currprofit;
            }
            j++;
        }
    }
    return profit;
   }

};
