Problem: Pow(x, n)
Topic: Binary Search, Math, Recursion (Binary Exponentiation)
Difficulty: Medium

Time Complexity: O(log n)
Space Complexity: O(1)


Code:
class Solution {
public:
    double myPow(double x, int n) {
        double ans=1.0;
        long long N=n;

        if(N<0){
            x=1/x;
            N= -N;

        }
        while(N>0){
            if(N%2==1){
                ans*=x;
            }
            x*=x;
            N/=2;
        }

        return ans;
    }
};
