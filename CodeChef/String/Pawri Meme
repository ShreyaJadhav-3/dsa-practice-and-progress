#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin>>t;
    while(t--){
        string s;
        cin>>s;
        
        if(s.empty()){
            cout<<s<<endl;
            continue;
        }
        
        if(s.length()<5){
            cout<<s<<endl;
            continue;
        }
        for(int i=0;i<=s.length()-5;i++){
           if(s.substr(i,5)=="party"){
            s.replace(i,5,"pawri");
            i+=4;
        }
        }
        cout<<s<<endl;
    }
    return 0;
}
